---
import "../styles/global.css";

import "@fontsource/inter/300.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";

// Подтягиваем URL файлов шрифтов для предзагрузки (Vite магия)
import inter400Cyrillic from "@fontsource/inter/files/inter-cyrillic-400-normal.woff2?url";
import inter400Latin from "@fontsource/inter/files/inter-latin-400-normal.woff2?url";
import inter700Cyrillic from "@fontsource/inter/files/inter-cyrillic-700-normal.woff2?url";
import inter700Latin from "@fontsource/inter/files/inter-latin-700-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Бюро Инженерно-Строительных Консультаций | Технадзор и Проектирование",
  description = "Профессиональный строительный контроль, аудит проектов и технический надзор. Экспертиза промышленных объектов с 2012 года.",
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- Font Preloading -->
    <link rel="preload" href={inter400Cyrillic} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={inter400Latin} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={inter700Cyrillic} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={inter700Latin} as="font" type="font/woff2" crossorigin="anonymous" />

    <!-- SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="технадзор, строительный контроль, технический надзор, проектирование инженерных систем, аудит строительства, ревизия проектов, сметная документация, ОВиК, вентиляция, отопление, кондиционирование, строительная экспертиза, Москва"
    />
    <meta name="author" content="Бюро инженерно-строительных консультаций" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://buro-isk.ru/" />

    <!-- Open Graph / Facebook / Telegram -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="Бюро инженерно-строительных консультаций" />
    <meta property="og:title" content="Технадзор и проектирование инженерных систем | Бюро ИСК" />
    <meta
      property="og:description"
      content="Профессиональный технический надзор, аудит проектов и ревизия смет. Работаем с 2012 года. Экономим до 30% бюджета."
    />
    <meta property="og:image" content="/images/hero-bg.jpg" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/favicon.png" />
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <slot />
  </body>
</html>
