---
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";

const reader = createReader(process.cwd(), keystaticConfig);
const servicesRaw = await reader.collections.services.all();
const services = servicesRaw.sort((a, b) => (a.entry.order || 0) - (b.entry.order || 0));
---

<header class="bg-white/95 backdrop-blur-md shadow-sm z-20 sticky top-0">
  <div class="container mx-auto px-4 md:px-6 h-16 flex items-center justify-between">
    <!-- Логотип -->
    <a href="#" class="flex items-center gap-2.5 shrink-0">
      <img
        src="/images/favicon.png"
        alt="Логотип"
        class="w-9 h-9 rounded-md"
      />
      <span class="hidden sm:block font-semibold text-sm text-gray-800 leading-tight">
        Бюро инженерно-<br />строительных консультаций
      </span>
    </a>

    <!-- Десктопная навигация -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Основная навигация">
      <a
        href="#about"
        class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary transition rounded-md hover:bg-gray-50">
        О нас
      </a>

      <!-- Dropdown Услуги -->
      <div class="relative group">
        <a
          href="#services"
          class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary transition rounded-md hover:bg-gray-50 flex items-center gap-1">
          Услуги
          <svg
            class="w-3.5 h-3.5 group-hover:rotate-180 transition-transform"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
        <div class="absolute left-0 top-full pt-2 hidden group-hover:block w-64 z-50">
          <ul
            class="bg-white shadow-xl rounded-lg border border-gray-100 py-1.5 text-gray-600 text-sm">
            {
              services.map((service) => (
                <li>
                  <a
                    href={`#service-${service.slug}`}
                    class="block px-4 py-2 hover:bg-primary/5 hover:text-primary transition">
                    {service.entry.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <a
        href="#portfolio"
        class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary transition rounded-md hover:bg-gray-50">
        Портфолио
      </a>
      <a
        href="#form"
        class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary transition rounded-md hover:bg-gray-50">
        Контакты
      </a>
    </nav>

    <!-- CTA кнопка -->
    <a
      href="#form"
      class="hidden md:inline-flex items-center gap-2 bg-primary hover:bg-primaryHover text-white text-sm font-semibold px-4 py-2 rounded-md transition shadow-sm">
      Оставить заявку
    </a>

    <!-- Мобильная навигация -->
    <nav class="md:hidden flex items-center gap-1 -mx-1">
      <a
        href="#about"
        class="px-2.5 py-1.5 text-xs font-semibold text-gray-600 hover:text-primary whitespace-nowrap">
        О нас
      </a>
      <a
        href="#services"
        class="px-2.5 py-1.5 text-xs font-semibold text-gray-600 hover:text-primary whitespace-nowrap">
        Услуги
      </a>
      <a
        href="#portfolio"
        class="px-2.5 py-1.5 text-xs font-semibold text-gray-600 hover:text-primary whitespace-nowrap">
        Проекты
      </a>
      <a href="#form" class="px-2.5 py-1.5 text-xs font-semibold text-primary whitespace-nowrap">
        Контакты
      </a>
    </nav>
  </div>
</header>
