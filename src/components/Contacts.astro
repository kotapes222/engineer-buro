---
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";

const reader = createReader(process.cwd(), keystaticConfig);
const settings = await reader.singletons.settings.read();
---

<section id="contacts" class="py-16 md:py-24 bg-secondary text-white">
  <div class="container mx-auto px-4 md:px-6 max-w-4xl text-center">
    <span class="section-label">Свяжитесь с нами</span>
    <h2 class="text-3xl md:text-4xl font-bold mb-12">Контакты</h2>

    <div class="space-y-4 max-w-min mx-auto">
      <div class="flex items-center justify-between gap-4 rounded-xl border border-white/20 bg-white/10 px-6 py-4">
        <div class="text-left">
          <div class="text-sm text-gray-300">Telegram</div>
          <a
            href="https://t.me/+79060190513"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white text-base font-semibold hover:text-primary transition">
            
          </a>
        </div>
        <a
          href="https://t.me/+79060190513"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/20 bg-white/10 text-white transition hover:bg-white/20 hover:text-primary">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        </a>
      </div>

      <div class="flex items-center justify-between gap-4 rounded-xl border border-white/20 bg-white/10 px-6 py-4">
        <div class="text-left">
          <div class="text-sm text-gray-300">Телефон</div>
          <a
            href={`tel:${settings?.phone || "+7 900 000-00-00"}`}
            class="text-white text-base font-semibold hover:text-primary transition">
            {settings?.phone || "+7 900 000-00-00"}
          </a>
        </div>
        <a
          href={`tel:${settings?.phone || "+7 900 000-00-00"}`}
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/20 bg-white/10 text-white transition hover:bg-white/20 hover:text-primary">
          <span class="text-xl">📞</span>
        </a>
      </div>

      <div class="flex items-center justify-between gap-4 rounded-xl border border-white/20 bg-white/10 px-6 py-4">
        <div class="text-left">
          <div class="text-sm text-gray-300">Email</div>
          <a
            href={`mailto:${settings?.email || "info@example.com"}`}
            class="text-white text-base font-semibold hover:text-primary transition">
            {settings?.email || "info@example.com"}
          </a>
        </div>
        <a
          href={`mailto:${settings?.email || "info@example.com"}`}
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/20 bg-white/10 text-white transition hover:bg-white/20 hover:text-primary">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 2v.01L12 11 4 6.01V6h16zm0 12H4V8.99l8 5 8-5V18z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
